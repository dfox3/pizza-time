{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/^version = \".*\"/version = \"${nextRelease.version}\"/' pyproject.toml && sed -i 's/^__version__ = \".*\"/__version__ = \"${nextRelease.version}\"/' src/dfizza/__init__.py && sed -i '/^name = \"dfizza\"$/,/^$/ s/^version = \".*\"/version = \"${nextRelease.version}\"/' uv.lock"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["pyproject.toml", "src/dfizza/__init__.py", "uv.lock"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    ["@semantic-release/npm", { "pkgRoot": "web/vite-react" }],
    "@semantic-release/github"
  ]
}
